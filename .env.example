# Copy to .env and fill in — .env is gitignored, this file is just documentation.
# Loaded automatically by ingestion/fetch_waqi.py and backend/main.py via
# python-dotenv — no manual `export` needed, just fill in the values below.

# Free token, ~10 seconds, no approval wait: https://aqicn.org/data-platform/token/
WAQI_TOKEN=your_token_here

# Powers multilingual citizen advisory translation (agents/translation_agent.py),
# via OpenRouter — one API in front of many models, several genuinely free.
# Get a free key: https://openrouter.ai/keys (no card required for the
# free-tier models). Optional: without it, the Citizen Advisory language
# selector still works for English (fully deterministic, no LLM), and
# gracefully falls back to English with a "Translation unavailable" badge
# for every other language instead of failing.
OPENROUTER_API_KEY=your_key_here

# Which OpenRouter model to translate with — defaults to a free model
# (agents/translation_agent.py::DEFAULT_MODEL) if left unset. Only need to
# set this if you want a different one; browse current free models
# (price = $0) at https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
